# Shell scripts must always be LF + executable, regardless of OS that committed them.
*.sh text eol=lf
*.sh diff
backendHub/entrypoint.sh text eol=lf executable

# Other files: let git autodetect, but normalize to LF in the repo
* text=auto eol=lf

# Binary files — never touch line endings
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.mp3 binary
*.wav binary
*.ogg binary
*.webm binary
*.pdf binary
*.zip binary
*.gz binary
*.sqlite3 binary
